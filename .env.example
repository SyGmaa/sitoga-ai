# ──────────────────────────────────────────────────────────────────────────────
# 🌿 SITOGA AI - CONFIGURATION TEMPLATE
# ──────────────────────────────────────────────────────────────────────────────
# Salin file ini ke .env dan isi dengan data yang sesuai.
# JANGAN PERNAH menyebarkan file .env asli Anda ke internet.

# ───────────── DATABASE (POSTGRESQL) ─────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/sitoga_ai_db"

# (Opsional) Digunakan untuk migrasi jika menggunakan connection pooling
# DIRECT_URL="postgresql://username:password@localhost:5432/sitoga_ai_db"

# ───────────── AUTHENTICATION (NEXT-AUTH) ─────────────
# Jalankan perintah ini untuk generate secret: 'openssl rand -base64 32'
NEXTAUTH_SECRET="gunakan_perintah_di_atas_untuk_generate_secret_anda"

# URL dasar aplikasi (wajib diisi untuk production)
# Local: http://localhost:3000
# Prod: https://nama-aplikasi-anda.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ───────────── APP CONFIGURATION ─────────────
# URL publik aplikasi (depan)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ───────────── AI ENGINE CONFIG (FALLBACK) ─────────────
# Catatan: Model utama dikelola via Menu Admin di database. 
# Variabel di sini hanya digunakan jika database belum terkonfigurasi.

# Pilih provider default: "google" atau "openrouter"
AI_PROVIDER=google

# Nama model default yang dipakai (Fallback)
# Google: gemini-2.5-flash / gemini-2.5-flash-lite / gemini-3.0-flash
# OpenRouter: mistralai/mistral-small-3.1-24b-instruct:free
AI_MODEL=gemini-2.5-flash

# ───────────── AI API KEYS ─────────────
# Pastikan tidak ada spasi di awal atau akhir API key.

# Google AI Studio: https://aistudio.google.com/app/apikey (GRATIS)
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXX

# OpenRouter: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXX

DATABASE_URL="postgresql://username:password@localhost:5432/sitoga_ai_db"

# === AI Provider Config ===
# Pilih provider: "google" atau "openrouter"
AI_PROVIDER=openrouter

# Nama model yang dipakai
# Rekomendasi Google: gemini-2.5-flash / gemini-2.0-flash
# Rekomendasi OpenRouter: arcee-ai/trinity-large-preview:free / mistralai/mistral-small-3.1-24b-instruct:free / deepseek/deepseek-v3.2
AI_MODEL=arcee-ai/trinity-large-preview:free

# === API Keys ===
# Dapatkan di: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_studio_api_key_here

# Dapatkan di: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
